<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="@drawable/bg_luxury_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeColor="#33FFFFFF"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_luxury_header"
                android:minHeight="168dp"
                android:padding="20dp">

                <FrameLayout
                    android:id="@+id/logoPlate"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:background="@drawable/bg_luxury_logo_plate"
                    android:padding="8dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/ivSerelunaLogo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/splash" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvSettingEyebrow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/raleway_bold"
                    android:text="Sereluna"
                    android:textColor="@color/brand_blush"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/logoPlate"
                    app:layout_constraintTop_toTopOf="@id/logoPlate" />

                <TextView
                    android:id="@+id/tvSettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/raleway_bold"
                    android:text="Pengaturan"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/logoPlate"
                    app:layout_constraintTop_toBottomOf="@id/tvSettingEyebrow" />

                <TextView
                    android:id="@+id/tvSettingsSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="@font/raleway_medium"
                    android:lineSpacingExtra="2dp"
                    android:text="Ruang personal yang tenang untuk akun, privasi, dan tema."
                    android:textColor="#EDE3F4"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/logoPlate" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/raleway_bold"
            android:text="Profil"
            android:textColor="@color/brand_purple_dark"
            android:textSize="16sp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/profileImage"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/profile_image"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="?attr/colorOnBackground"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/profileImage"
                app:layout_constraintTop_toTopOf="@id/profileImage"
                tools:text="Admiral" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/raleway_medium"
                android:textColor="@color/gray_500"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/profileImage"
                app:layout_constraintTop_toBottomOf="@id/tvUsername"
                tools:text="admiral@sereluna.com" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Akun Section -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="Akun" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/itemEditProfile"
                    layout="@layout/item_setting_row" />

                <View style="@style/SettingsDivider" />

                <include
                    android:id="@+id/itemChangePassword"
                    layout="@layout/item_setting_row" />

                <View style="@style/SettingsDivider" />

                <include
                    android:id="@+id/itemResetEmail"
                    layout="@layout/item_setting_row" />

                <View style="@style/SettingsDivider" />

                <include
                    android:id="@+id/itemDeleteAccount"
                    layout="@layout/item_setting_row" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Preferensi Section -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="Tampilan &amp; Tema" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/themeToggleGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeDefault"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sistem"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_theme_auto_24"
                        app:iconGravity="top"
                        app:iconPadding="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeLight"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Terang"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_theme_light_24"
                        app:iconGravity="top"
                        app:iconPadding="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeDark"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gelap"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_theme_dark_24"
                        app:iconGravity="top"
                        app:iconPadding="4dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Legal Section -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="Informasi &amp; Legal" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                    <include
                        android:id="@+id/itemTerms"
                        layout="@layout/item_setting_row" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/itemPrivacy"
                        layout="@layout/item_setting_row" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:fontFamily="@font/raleway_bold"
            android:text="Keluar dari Akun"
            android:textColor="@color/white"
            app:backgroundTint="@color/brand_plum_800"
            app:cornerRadius="18dp" />

    </LinearLayout>
</ScrollView>
