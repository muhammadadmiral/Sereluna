<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="?attr/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/raleway_bold"
            android:text="Pengaturan"
            android:textColor="@color/brand_purple_primary"
            android:textSize="28sp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/profileImage"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/profile_image"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="?attr/colorOnBackground"
                android:textSize="20sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/profileImage"
                app:layout_constraintTop_toTopOf="@id/profileImage"
                tools:text="Admiral" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/raleway_medium"
                android:textColor="@color/gray_500"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/profileImage"
                app:layout_constraintTop_toBottomOf="@id/tvUsername"
                tools:text="admiral@sereluna.com" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Akun Section -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="Akun" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:id="@+id/itemEditProfile"
                    layout="@layout/item_setting_row" />

                <View style="@style/SettingsDivider" />

                <include
                    android:id="@+id/itemChangePassword"
                    layout="@layout/item_setting_row" />

                <View style="@style/SettingsDivider" />

                <include
                    android:id="@+id/itemResetEmail"
                    layout="@layout/item_setting_row" />

                <View style="@style/SettingsDivider" />

                <include
                    android:id="@+id/itemDeleteAccount"
                    layout="@layout/item_setting_row" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Preferensi Section -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="Preferensi" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/raleway_medium"
                    android:text="Mode Gelap"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Legal Section -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="Informasi &amp; Legal" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                    <include
                        android:id="@+id/itemTerms"
                        layout="@layout/item_setting_row" />

                    <View style="@style/SettingsDivider" />

                    <include
                        android:id="@+id/itemPrivacy"
                        layout="@layout/item_setting_row" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:fontFamily="@font/raleway_bold"
            android:text="Keluar dari Akun"
            android:textColor="@color/white"
            app:backgroundTint="@color/brand_purple_primary"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>
