<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_luxury_app"
    android:fillViewport="true"
    tools:context=".ui.article.ArticleDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back_button_description"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="?attr/colorOnBackground" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/ivDetailImage"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="?attr/colorSurfaceVariant"
                android:scaleType="centerCrop"
                tools:src="@drawable/article" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvDetailTopic"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_luxury_logo_plate"
            android:fontFamily="@font/raleway_bold"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textSize="12sp"
            tools:text="Cemas" />

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/raleway_bold"
            android:lineSpacingExtra="2dp"
            android:text="@string/article_title"
            android:textColor="?attr/colorOnBackground"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tvDetailDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/raleway_medium"
            android:text="@string/article_date"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvDetailContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/raleway_medium"
            android:lineSpacingExtra="4dp"
            android:text="@string/article_content"
            android:textColor="?attr/colorOnBackground"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvContentWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/raleway_medium"
                android:lineSpacingExtra="3dp"
                android:padding="14dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="13sp"
                tools:text="Artikel eksternal. Gunakan sebagai bacaan pendukung." />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenArticle"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/raleway_bold"
            android:text="Buka Artikel"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotifyArticle"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/raleway_bold"
            android:text="Ingatkan lewat Notifikasi"
            app:cornerRadius="18dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
